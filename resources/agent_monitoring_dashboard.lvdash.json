{
  "datasets": [
    {
      "name": "traces",
      "displayName": "Profilr Traces",
      "queryLines": [
        "SELECT * FROM mlops_dev.alessand.profilr_traces_aggregated"
      ],
      "columns": [
        {
          "displayName": "Request Date",
          "description": "Date extracted from request_time for time-series grouping",
          "expression": "DATE(request_time)"
        },
        {
          "displayName": "Quality Score",
          "description": "Average pass rate across all 5 quality checks (0-100)",
          "expression": "ROUND((under_300_words + summary_not_empty + has_facts_section + professional_tone + factual_content) / 5.0 * 100, 1)"
        },
        {
          "displayName": "Request Hour",
          "description": "Hour of day from request_time for hourly distribution",
          "expression": "HOUR(request_time)"
        }
      ]
    }
  ],
